---
import MainLayout from '../../layouts/MainLayout.astro'
import TagList from '../../components/TagList.astro'
import PostList from '../../components/PostList.astro'
import ResourceList from '../../components/ResourceList.astro'
import { Image } from 'astro:assets'
import { getCollection, getEntry, render } from 'astro:content'

export async function getStaticPaths() {
  const resources = await getCollection('resources')
  return resources.map(p => ({
    params: { id: p.id },
  }))
}

const { id } = Astro.params

const resource = await getEntry('resources', id)

if (!resource) {
  throw new Error(`Resource ${resource} not found`)
}

const { Content } = await render(resource)
const title = `Resources on ${resource.data.title}`
---

<MainLayout title={title}>
  <article>
    <h1>{title}</h1>
    <p>Last updated <time datetime={resource.data.updated}>{resource.data.updated}</time></p>
    <TagList tags={resource.data.tags} />
    <Content />
    <hr />
    {resource.data.tags.map(tag => <>
      <h3>Resources tagged <span class="smallcaps">{tag}</span></h3>
      <ResourceList tag={tag} />
    </>)}
    {resource.data.tags.map(tag => <>
      <h3>Posts tagged <span class="smallcaps">{tag}</span></h3>
      <PostList tag={tag} />
    </>)}
  </article>
</MainLayout>
